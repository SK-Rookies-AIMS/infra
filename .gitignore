# AWS / SSH / Secrets
# ------------------------------------------------------------

*.pem
*.key
*.pub
*.ppk
.env
*.env
secrets.*
credentials
config.aws

# ------------------------------------------------------------
# Project temp files
# ------------------------------------------------------------

terraform/*.md
manifests/*.txt

