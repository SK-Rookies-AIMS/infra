# ------------------------------------------------------------
# Terraform
# ------------------------------------------------------------

# Terraform local working directory
**/.terraform/*
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Terraform variable files
*.tfvars
*.tfvars.json

# Keep example tfvars files
!*.tfvars.example
!*.tfvars.sample

# Terraform plan files
*.tfplan
*.plan

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

